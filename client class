package crms;

// This class represents a client in the Car Rental Management System
public class Client {

    // Unique identifier for the client
    private String id;

    // Name of the client
    private String name;

    // Constructor to initialize client ID and name
    public Client(String id, String name) {
        this.id = id;
        this.name = name;
    }

    // Getter method to return the client ID
    public String getId() {
        return id;
    }

    // Getter method to return the client name
    public String getName() {
        return name;
    }

    // Setter method to update the client name
    public void setName(String name) {
        this.name = name;
    }

    // This method returns a readable string representation of the client
    @Override
    public String toString() {
        return "Client ID: " + id + ", Name: " + name;
    }
}
}
